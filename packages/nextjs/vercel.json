{
  "installCommand": "npm install --legacy-peer-deps --no-workspaces",
  "buildCommand": "NEXT_PUBLIC_IPFS_BUILD=true NEXT_PUBLIC_IGNORE_BUILD_ERROR=true npm run build",
  "outputDirectory": "out",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ],
  "routes": [
    { "src": "^/(_next)(.*)", "dest": "/$1$2" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/(borrower|lender|docs|request)/?$", "dest": "/$1/index.html" },
    { "src": ".*", "dest": "/404.html", "status": 404 }
  ]
}
